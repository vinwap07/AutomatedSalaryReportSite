@page
@model WebApp.Pages.Reports.IndexModel
@{
    ViewData["Title"] = Model.IsAdmin ? "Отчёт по работам" : "Мои работы";
    var today = DateOnly.FromDateTime(DateTime.Today);
    var thisMonthStart = new DateOnly(today.Year, today.Month, 1);
    var prevMonthStart = thisMonthStart.AddMonths(-1);
    var prevMonthEnd = thisMonthStart.AddDays(-1);
    var weekStart = today.AddDays(-6);
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="h3 m-0">@ViewData["Title"]</h1>
    @if (!Model.IsAdmin && Model.OwnEmployee != null)
    {
        <span class="text-muted">@Model.OwnEmployee.Name</span>
    }
</div>

@if (!Model.IsAdmin && Model.OwnEmployee == null)
{
    <div class="alert alert-warning">
        К вашей учётной записи не привязан работник. Обратитесь к администратору.
    </div>
    return;
}

<div class="card mb-3">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-6 col-md-2">
                <label class="form-label mb-1">С</label>
                <input type="date" name="From" value="@Model.From?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label mb-1">По</label>
                <input type="date" name="To" value="@Model.To?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            @if (Model.IsAdmin)
            {
                <div class="col-12 col-md-3">
                    <label class="form-label mb-1">Работник</label>
                    <select name="EmployeeId" class="form-select">
                        <option value="">Все работники</option>
                        @foreach (var employee in Model.Employees)
                        {
                            <option value="@employee.Id" selected="@(employee.Id == Model.EmployeeId)">@employee.Name</option>
                        }
                    </select>
                </div>
            }
            <div class="col-12 col-md-2">
                <button type="submit" class="btn btn-primary w-100">Показать</button>
            </div>
            <div class="col-12 col-md-3 d-flex flex-wrap gap-1">
                <a class="btn btn-outline-secondary btn-sm"
                   asp-page="/Reports/Index"
                   asp-route-From="@thisMonthStart.ToString("yyyy-MM-dd")"
                   asp-route-To="@today.ToString("yyyy-MM-dd")"
                   asp-route-EmployeeId="@Model.EmployeeId">Этот месяц</a>
                <a class="btn btn-outline-secondary btn-sm"
                   asp-page="/Reports/Index"
                   asp-route-From="@prevMonthStart.ToString("yyyy-MM-dd")"
                   asp-route-To="@prevMonthEnd.ToString("yyyy-MM-dd")"
                   asp-route-EmployeeId="@Model.EmployeeId">Прошлый месяц</a>
                <a class="btn btn-outline-secondary btn-sm"
                   asp-page="/Reports/Index"
                   asp-route-From="@weekStart.ToString("yyyy-MM-dd")"
                   asp-route-To="@today.ToString("yyyy-MM-dd")"
                   asp-route-EmployeeId="@Model.EmployeeId">Неделя</a>
            </div>
        </form>
    </div>
</div>

<div class="row g-2 mb-3">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label">Итого заработано</div>
            <div class="stat-value text-success">@Model.TotalSum.ToString("N2") ₽</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label">Часов</div>
            <div class="stat-value">@Model.TotalHours</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label">Дней с работой</div>
            <div class="stat-value">@Model.WorkDaysCount</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label">Отсутствий</div>
            <div class="stat-value">@Model.AbsenceCount</div>
        </div>
    </div>
</div>

@if (Model.EmployeeSummary.Count > 0)
{
    <h2 class="h5 mt-4">Сводка по работникам</h2>
    <div class="table-responsive mb-4">
        <table class="table table-sm table-hover align-middle bg-white table-stack" style="max-width: 900px">
            <thead class="table-light">
            <tr>
                <th>Работник</th>
                <th class="num">Дней</th>
                <th class="num">Часов</th>
                <th class="num">Отсутствий</th>
                <th class="num">Сумма</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.EmployeeSummary)
            {
                <tr>
                    <td data-label="Работник" class="fw-semibold">@row.Name</td>
                    <td data-label="Дней" class="num">@row.WorkDays</td>
                    <td data-label="Часов" class="num">@row.Hours</td>
                    <td data-label="Отсутствий" class="num">@row.Absences</td>
                    <td data-label="Сумма" class="num fw-semibold">@row.Sum.ToString("N2") ₽</td>
                </tr>
            }
            </tbody>
            <tfoot>
            <tr class="table-light fw-bold">
                <td data-label="">Итого</td>
                <td data-label="Дней" class="num">@Model.WorkDaysCount</td>
                <td data-label="Часов" class="num">@Model.TotalHours</td>
                <td data-label="Отсутствий" class="num">@Model.AbsenceCount</td>
                <td data-label="Сумма" class="num">@Model.TotalSum.ToString("N2") ₽</td>
            </tr>
            </tfoot>
        </table>
    </div>
    <h2 class="h5">По дням</h2>
}

@if (Model.Days.Count == 0)
{
    <div class="alert alert-secondary">За выбранный период записей нет.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle bg-white table-stack">
            <thead class="table-light">
            <tr>
                @if (Model.ShowEmployeeColumn)
                {
                    <th>Работник</th>
                }
                <th>Работа / отсутствие</th>
                <th class="num">Часы</th>
                <th class="num">Расценка</th>
                <th class="num">Объём</th>
                <th class="num">Сумма</th>
            </tr>
            </thead>
            <tbody>
            @{
                var columnCount = Model.ShowEmployeeColumn ? 6 : 5;
            }
            @foreach (var day in Model.Days)
            {
                <tr class="day-header">
                    <td colspan="@(columnCount - 1)">📅 @day.Date.ToString("d MMMM yyyy, dddd")</td>
                    <td class="num">@day.DaySum.ToString("N2") ₽</td>
                </tr>
                @foreach (var log in day.Logs)
                {
                    <tr>
                        @if (Model.ShowEmployeeColumn)
                        {
                            <td data-label="Работник">@log.Employee.Name</td>
                        }
                        <td data-label="Работа">
                            @if (log.ReasonForAbsence != null)
                            {
                                <span class="badge text-bg-warning">@log.ReasonForAbsence.Name</span>
                            }
                            else
                            {
                                @(log.WorkType?.Name ?? "—")
                            }
                        </td>
                        <td data-label="Часы" class="num">@(log.WorkHours?.ToString() ?? "—")</td>
                        <td data-label="Расценка" class="num">@(log.WorkCost?.Rate.ToString("N2") ?? "—")</td>
                        <td data-label="Объём" class="num">
                            @if (log.WorkCost != null)
                            {
                                @log.WorkCost.Volume.ToString("0.##") <span class="text-muted small">@log.WorkCost.UnitOfMeasure.GetDisplayName()</span>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>
                        <td data-label="Сумма" class="num fw-semibold">@(log.WorkCost?.Total.ToString("N2") ?? "—")</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
}
