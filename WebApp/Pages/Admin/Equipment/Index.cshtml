@page
@model WebApp.Pages.Admin.Equipment.IndexModel
@{
    ViewData["Title"] = "Техника";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="h3 m-0">Техника</h1>
</div>

<div class="card mb-3">
    <div class="card-body py-3">
        <form method="post" asp-page-handler="Create" class="row g-2 align-items-end">
            <div class="col-12 col-md-5">
                <label class="form-label mb-1">Название</label>
                <input name="Name" class="form-control" required placeholder="Например: МТЗ-82" />
            </div>
            <div class="col-6 col-md-3">
                <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" name="HasTracker" value="true" id="hasTrackerNew" />
                    <label class="form-check-label" for="hasTrackerNew">Есть трекер</label>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <button type="submit" class="btn btn-success w-100">Добавить</button>
            </div>
        </form>
    </div>
</div>

@if (Model.Items.Count == 0)
{
    <div class="alert alert-secondary">Техника ещё не добавлена.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle bg-white" style="max-width: 720px">
            <thead class="table-light">
            <tr>
                <th>Название</th>
                <th>Трекер</th>
                <th style="width:160px"></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                if (item.Id == Model.EditId)
                {
                    <tr>
                        <td colspan="3">
                            <form method="post" asp-page-handler="Update" asp-route-id="@item.Id" class="d-flex flex-wrap gap-2 align-items-center">
                                <input name="Name" value="@item.Name" class="form-control form-control-sm" style="max-width:280px" required />
                                <div class="form-check m-0">
                                    <input class="form-check-input" type="checkbox" name="HasTracker" value="true" id="tracker_@item.Id" checked="@item.HasTracker" />
                                    <label class="form-check-label" for="tracker_@item.Id">Трекер</label>
                                </div>
                                <button type="submit" class="btn btn-success btn-sm">Сохранить</button>
                                <a class="btn btn-outline-secondary btn-sm" asp-page="/Admin/Equipment/Index">Отмена</a>
                            </form>
                        </td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@(item.HasTracker ? "✅ есть" : "—")</td>
                        <td>
                            <div class="d-flex gap-1 justify-content-end">
                                <a class="btn btn-outline-primary btn-sm" asp-page="/Admin/Equipment/Index" asp-route-EditId="@item.Id">✎</a>
                                <form method="post" asp-page-handler="Delete" data-confirm="Удалить технику «@item.Name»?" class="m-0">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="name" value="@item.Name" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm">✕</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
}
