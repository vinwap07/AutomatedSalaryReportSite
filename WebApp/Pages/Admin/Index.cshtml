@page
@model WebApp.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Журнал работ";
    var routeFilters = new Dictionary<string, string?>
    {
        ["From"] = Model.From?.ToString("yyyy-MM-dd"),
        ["To"] = Model.To?.ToString("yyyy-MM-dd"),
        ["EmployeeId"] = Model.EmployeeId?.ToString(),
        ["WorkTypeId"] = Model.WorkTypeId?.ToString(),
    };
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="h3 m-0">Журнал работ</h1>
    <a class="btn btn-success" asp-page="/Admin/AddDay">＋ Добавить день</a>
</div>

<div class="card mb-3">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-6 col-md-2">
                <label class="form-label mb-1">С</label>
                <input type="date" name="From" value="@Model.From?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label mb-1">По</label>
                <input type="date" name="To" value="@Model.To?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label mb-1">Работник</label>
                <select name="EmployeeId" class="form-select">
                    <option value="">Все работники</option>
                    @foreach (var employee in Model.Employees)
                    {
                        <option value="@employee.Id" selected="@(employee.Id == Model.EmployeeId)">@employee.Name</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label mb-1">Вид работы</label>
                <select name="WorkTypeId" class="form-select">
                    <option value="">Все виды работ</option>
                    @foreach (var workType in Model.WorkTypes)
                    {
                        <option value="@workType.Id" selected="@(workType.Id == Model.WorkTypeId)">@workType.Name</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">Показать</button>
                <a class="btn btn-outline-secondary" asp-page="/Admin/Index">Сброс</a>
            </div>
        </form>
    </div>
</div>

<div class="row g-2 mb-3">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label">Итого за период</div>
            <div class="stat-value">@Model.TotalSum.ToString("N2") ₽</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label">Часов</div>
            <div class="stat-value">@Model.TotalHours</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label">Дней</div>
            <div class="stat-value">@Model.Days.Count</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label">Записей</div>
            <div class="stat-value">@Model.TotalRecords</div>
        </div>
    </div>
</div>

@if (Model.Days.Count == 0)
{
    <div class="alert alert-secondary">За выбранный период записей нет.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle bg-white table-stack">
            <thead class="table-light">
            <tr>
                <th>Работник</th>
                <th>Техника</th>
                <th>Работа / отсутствие</th>
                <th class="num">Часы</th>
                <th class="num">Расценка</th>
                <th class="num">Объём</th>
                <th class="num">Сумма</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var day in Model.Days)
            {
                <tr class="day-header">
                    <td colspan="6">
                        📅 @day.Date.ToString("d MMMM yyyy, dddd")
                        <a class="ms-2 small" asp-page="/Admin/AddDay" asp-route-Date="@day.Date.ToString("yyyy-MM-dd")">＋ добавить</a>
                    </td>
                    <td class="num">@day.DaySum.ToString("N2") ₽</td>
                    <td></td>
                </tr>
                @foreach (var log in day.Logs)
                {
                    <tr>
                        <td data-label="Работник">@log.Employee.Name</td>
                        <td data-label="Техника" class="text-muted">@(string.IsNullOrEmpty(log.Employee.EquipmentName) ? "—" : log.Employee.EquipmentName)</td>
                        <td data-label="Работа">
                            @if (log.ReasonForAbsence != null)
                            {
                                <span class="badge text-bg-warning">@log.ReasonForAbsence.Name</span>
                            }
                            else
                            {
                                @(log.WorkType?.Name ?? "—")
                            }
                        </td>
                        <td data-label="Часы" class="num">@(log.WorkHours?.ToString() ?? "—")</td>
                        <td data-label="Расценка" class="num">@(log.WorkCost?.Rate.ToString("N2") ?? "—")</td>
                        <td data-label="Объём" class="num">
                            @if (log.WorkCost != null)
                            {
                                @log.WorkCost.Volume.ToString("0.##") <span class="text-muted small">@log.WorkCost.UnitOfMeasure.GetDisplayName()</span>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>
                        <td data-label="Сумма" class="num fw-semibold">@(log.WorkCost?.Total.ToString("N2") ?? "—")</td>
                        <td data-label="">
                            <div class="d-flex gap-1 justify-content-end">
                                <a class="btn btn-outline-primary btn-sm" asp-page="/Admin/EditWorkLog" asp-route-id="@log.Id">✎</a>
                                <form method="post" asp-page-handler="Delete" asp-all-route-data="routeFilters"
                                      data-confirm="Удалить запись: @log.Employee.Name, @day.Date.ToString("dd.MM.yyyy")?" class="m-0">
                                    <input type="hidden" name="id" value="@log.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm">✕</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
}
